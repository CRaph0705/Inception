[DEFAULT]
bantime = 180
findtime = 600
maxretry = 3

[Definition]
failregex = ^.*\[pid \d+\] \[.*\] FTP response: Client "<HOST>", "530.*"
ignoreregex =
allowipv6 = auto

# service
[vsftpd]
enabled = true
port = ftp
filter = vsftpd
logpath = /var/log/vsftpd/vsftpd.log

[nginx-http-auth]
enabled = true
port = http, https
logpath = /var/log/nginx/error.log

[sshd]
enabled = false